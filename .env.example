PORT=3000

# Canonical feed: generated by RSForwarder/export_ngk_amazon_deals.py.
# Relative paths are resolved from this ngkflip-main folder.
DEAL_FEED_PATH=../RSForwarder/exports/ngk_amazon_deals.json
DEAL_REFRESH_MS=300000
MAX_DEALS=24

# Optional: protects /api/deals/refresh?key=...
ADMIN_REFRESH_KEY=change_me

# Optional only for /api/asin/:asin lookups. The main deals feed does not need these.
ACCESS_KEY=
SECRET_KEY=
PARTNER_TAG=leadflips-20

# Optional fallback only. Prefer the RSForwarder JSON feed so Discord tokens stay out of this app.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_MESSAGE_LIMIT=50
